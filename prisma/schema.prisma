generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Product {
  id            String   @id @default(cuid())
  brand         String
  model         String
  processor     String?
  ram           String?
  storage       String?
  display       String?
  graphics      String?
  features      String?  @db.Text
  originalPrice Float?
  promoPrice    Float?
  quantity      Int      @default(0)
  imageUrl      String?
  isNew         Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
